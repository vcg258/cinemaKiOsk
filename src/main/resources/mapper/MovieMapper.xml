<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.cinemakiosk.mapper.MovieMapper">
    <select id="findBySeveral" resultType="com.example.cinemakiosk.dto.MovieDTO">
        SELECT * FROM movie
        <where>
            <if test="keyWord != null and keyWord != ''">
                AND title LIKE CONCAT('%', #{keyWord}, '%')
            </if>
            <if test="genre != null and genre != ''">
                AND genre = #{genre}
            </if>
            <if test="rating != null">
                AND rating = #{rating}
            </if>
        </where>
    </select>
</mapper>
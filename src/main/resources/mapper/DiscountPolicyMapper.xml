<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.cinemakiosk.mapper.DiscountPolicyMapper">
    <resultMap id="discountPolicyResultMap" type="com.example.cinemakiosk.dto.DiscountPolicyDTO">
        <id property="id" column="id"/>
        <result property="activation" column="activation"/>
        <result property="policyName" column="policy_name"/>
        <result property="discountType" column="discount_type"/>
        <result property="startAt" column="start_at"/>
        <result property="endAt" column="end_at"/>
        <result property="conditionType" column="condition_type"/>
        <result property="discountValue" column="discount_value"/>
        <collection property="coupons" ofType="com.example.cinemakiosk.dto.CouponDTO">
            <id property="couponNum" column="coupon_num"/>
            <result property="status" column="status"/>
            <result property="policyId" column="policy_id"/>
        </collection>
    </resultMap>

    <select id="checkCoupon" resultMap="discountPolicyResultMap">
        SELECT * FROM discount_policy DP
        JOIN coupon C ON DP.id = C.policy_id WHERE C.policy_id = #{policy_id}
    </select>

</mapper>
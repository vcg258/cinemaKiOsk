<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.cinemakiosk.mapper.AdminMapper">
    <resultMap id="AdminByAdminRoleName" type="com.example.cinemakiosk.vo.AdminVO">
        <id property="adminId" column="admin_Id"/>
        <result property="adminPhone" column="admin_phone"/>
        <result property="createAt" column="create_at"/>
        <result property="level" column="level"/>
        <result property="loginId" column="login_id"/>
        <result property="name" column="name"/>
        <result property="password" column="password"/>
        <collection property="permissions" ofType="String">
            <result column="role_name"/>
        </collection>
    </resultMap>

    <select id="selectAdminByAdminRole" resultMap="AdminByAdminRoleName">
        SELECT * FROM admin A
        LEFT OUTER JOIN admin_role_map ARM ON A.admin_id = ARM.admin_id
        LEFT JOIN admin_role ON ARM.role_id = admin_role.id
    </select>
</mapper>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.cinemakiosk.mapper.MemberMapper">

    <resultMap id="MemberVO" type="com.example.cinemakiosk.vo.MemberVO" autoMapping="true">
        <id property="phone" column="phone"/>
    </resultMap>

    <select id="selectOneById" resultMap="MemberVO">
        select
            mb.phone,
            mb.create_at,
            mb.point
        from cinema_kiosk.member mb
        where mb.phone = #{phone};
    </select>

    <select id="selectAll" resultMap="MemberVO">
        select
            mb.phone,
            mb.create_at,
            mb.point
        from cinema_kiosk.member mb;
    </select>
</mapper>